      }
    },
    "/api/CredentialConfig/claims/remove-field": {
      "delete": {
        "tags": [
          "Credential Config"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RemoveFieldRequest"
              }
            },
            "text/json": {
