  "components": {
    "schemas": {
      "AddFieldRequest": {
        "type": "object",
        "properties": {
          "field_name": {
            "type": "string",
            "nullable": true
          },
          "mandatory": {
            "type": "boolean"
          },
          "label_en": {
            "type": "string",
            "nullable": true
          },
          "label_th": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ClaimConfigInput": {
        "type": "object",
        "properties": {
          "mandatory": {
            "type": "boolean"
          },
          "display": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ClaimDisplayInput"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ClaimDisplayInput": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "nullable": true
          },
          "locale": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ClaimDisplayMetadata": {
        "required": [
          "label",
          "lang"
        ],
        "type": "object",
        "properties": {
          "lang": {
            "type": "string",
            "nullable": true
          },
          "label": {
            "type": "string",
            "nullable": true
          },
          "description": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ClaimMetadata": {
        "required": [
          "path"
        ],
        "type": "object",
        "properties": {
          "path": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "nullable": true
          },
          "display": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ClaimDisplayMetadata"
            },
            "nullable": true
          },
          "mandatory": {
            "type": "boolean",
            "nullable": true
          },
          "sd": {
            "type": "boolean",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "DisplayMetadata": {
        "required": [
          "lang",
          "name"
        ],
        "type": "object",
        "properties": {
          "lang": {
            "type": "string",
            "nullable": true
          },
          "name": {
            "type": "string",
            "nullable": true
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "rendering": {
            "$ref": "#/components/schemas/RenderingMetadata"
          }
        },
        "additionalProperties": false
      },
      "DocumentType": {
        "enum": [
          "Transcript",
          "IdCard",
          "DriverLicense",
          "BootCamp"
        ],
        "type": "string"
      },
      "GenerateQrRequest": {
        "type": "object",
        "properties": {
          "document_type": {
            "$ref": "#/components/schemas/DocumentType"
          }
        },
        "additionalProperties": false
      },
      "IssuanceRequest": {
        "type": "object",
        "properties": {
          "credential_configuration_id": {
            "type": "string",
            "nullable": true
          },
          "proof": {
            "$ref": "#/components/schemas/Proof"
          }
        },
        "additionalProperties": false
      },
      "LogoMetadata": {
        "required": [
          "uri"
        ],
        "type": "object",
        "properties": {
          "uri": {
            "type": "string",
            "nullable": true
          },
          "alt_text": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "Proof": {
        "type": "object",
        "properties": {
          "proof_type": {
            "type": "string",
            "nullable": true
          },
          "jwt": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "RemoveFieldRequest": {
        "type": "object",
        "properties": {
          "credential_type": {
            "type": "string",
            "nullable": true
          },
          "field_name": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "RenderingMetadata": {
        "type": "object",
        "properties": {
          "simple": {
            "$ref": "#/components/schemas/SimpleRendering"
          }
        },
        "additionalProperties": false
      },
      "SimpleRendering": {
        "type": "object",
        "properties": {
          "logo": {
            "$ref": "#/components/schemas/LogoMetadata"
          },
          "background_color": {
            "type": "string",
            "nullable": true
          },
          "text_color": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "UpsertClaimsRequest": {
        "type": "object",
        "properties": {
          "claims": {
            "type": "object",
            "additionalProperties": {
              "$ref": "#/components/schemas/ClaimConfigInput"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "VctTypeMetadata": {
        "required": [
          "vct"
        ],
        "type": "object",
        "properties": {
          "vct": {
            "type": "string",
            "nullable": true
          },
          "name": {
            "type": "string",
            "nullable": true
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "extends": {
            "type": "string",
            "nullable": true
          },
          "display": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DisplayMetadata"
            },
            "nullable": true
          },
          "claims": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ClaimMetadata"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "description": "ใส่ access token แบบนี้: Bearer {token}",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
    {
      "Bearer": []
    }
  ]
}