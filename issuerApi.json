{
  "openapi": "3.0.1",
  "info": {
    "title": "IssuerAPI",
    "version": "1.0"
  },
  "paths": {
    "/token": {
      "post": {
        "tags": [
          "Authorization & Token"
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "grant_type": {
                    "type": "string"
                  },
                  "pre-authorized_code": {
                    "type": "string"
                  },
                  "tx_code": {
                    "type": "string"
                  }
                }
              },
              "encoding": {
                "grant_type": {
                  "style": "form"
                },
                "pre-authorized_code": {
                  "style": "form"
                },
                "tx_code": {
                  "style": "form"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/credential": {
      "post": {
        "tags": [
          "Credenital Issuance"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IssuanceRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/IssuanceRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/IssuanceRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
