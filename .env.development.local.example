# Optional development overrides — copy to .env.development.local (gitignored).
# NOT required for first run. See docs/GETTING_STARTED.md.

# Optional override for wallet-initiated VP QR relay (defaults to wallet API origin without /wallet-api).
# EXPO_PUBLIC_VP_RELAY_BASE_URL=http://<windows-lan-ip>:4000

# Development-only wallet operation logs. Defaults to enabled in __DEV__ when unset.
# Set to false to mute [wallet:*] logs. Production builds ignore this flag and stay off.
EXPO_PUBLIC_ENABLE_WALLET_DEBUG_LOGS=true

# Comma-separated native cert resource names (no extension) bundled into the iOS/Android
# projects via Expo prebuild. Only used to pin HTTPS connections to the backend host
# (ADR 0005). Leave empty to disable pinning, e.g. for local HTTP dev backends.
EXPO_PUBLIC_WALLET_API_PINNED_CERTS=

# Office-network workaround: rewrites fetches to EXPO_PUBLIC_DEV_ISSUER_PROXY_TARGET
# to go through the local backend's /dev-issuer-proxy instead (see server/.env
# ENABLE_DEV_ISSUER_PROXY). Leave unset in normal/prod use.
EXPO_PUBLIC_DEV_ISSUER_PROXY_TARGET=
EXPO_PUBLIC_DEV_ISSUER_PROXY_BASE_URL=

# OID4VP Verifier API used by Scan for presentation testing.
# Example: http://192.100.10.48
EXPO_PUBLIC_VERIFIER_API_BASE_URL=
EXPO_PUBLIC_VERIFIER_NAME=Verifier API

# Optional production-style did:web verifier trust entry (hardware-free local testing).
# Client ID is normalized to decentralized_identifier:<did> when the prefix is omitted.
# EXPO_PUBLIC_VERIFIER_DID_WEB_CLIENT_ID=did:web:verifier.example.com
# EXPO_PUBLIC_VERIFIER_DID_WEB_RESPONSE_ORIGIN=https://verifier.example.com
# EXPO_PUBLIC_VERIFIER_DID_WEB_NAME=Trusted Verifier
# EXPO_PUBLIC_VERIFIER_DID_WEB_JWK={"kty":"OKP","crv":"Ed25519","x":"..."}
EXPO_PUBLIC_DEV_VERIFIER_PROXY_TARGET=
EXPO_PUBLIC_DEV_VERIFIER_PROXY_BASE_URL=

# NEVER enable for release builds — development-only Verifier compatibility.
EXPO_PUBLIC_DISABLE_SD_JWT_KB_FOR_TESTING=

# Wallet key TTL. Dev is ms (short values for testing), prod is days.
# Omit to use defaults (dev=300000ms i.e. 5min, prod=180 days).
EXPO_PUBLIC_WALLET_KEY_DEV_TTL_MS=300000
EXPO_PUBLIC_WALLET_KEY_PROD_TTL_DAYS=180

# App-lock PIN session grace (milliseconds). Default 300000ms (5 minutes).
EXPO_PUBLIC_WALLET_PIN_SESSION_GRACE_MS=300000

# Development-only OID4VP Verifier compatibility probes.
# EXPO_PUBLIC_VERIFIER_DCQL_VP_TOKEN_SHAPE=object_array
EXPO_PUBLIC_VERIFIER_DCQL_VP_TOKEN_SHAPE=
# EXPO_PUBLIC_VERIFIER_KB_AUD=client_id
EXPO_PUBLIC_VERIFIER_KB_AUD=

# Days before document expiry warnings. Default 30 when unset.
EXPO_PUBLIC_DOCUMENT_EXPIRY_WARNING_WINDOW_DAYS=30

# Issuer web portals for Wallet Home "ขอเอกสาร" flows.
EXPO_PUBLIC_ISSUER_PORTAL_THAI_NATIONAL_ID=
EXPO_PUBLIC_ISSUER_PORTAL_DLT=

# Dual-format issuance / NFC policy
EXPO_PUBLIC_DUAL_FORMAT_ISSUE_SKEW_MS=300000
EXPO_PUBLIC_HCE_ARM_WINDOW_MS=60000
EXPO_PUBLIC_NFC_PAYLOAD_MAX_BYTES=65536

# Remote OID4VP presentation-definition fetch policy
# Timeout in ms before aborting PD fetch (default 15000).
EXPO_PUBLIC_PRESENTATION_DEFINITION_FETCH_TIMEOUT_MS=15000
# Max PD response body size in bytes (default 65536).
EXPO_PUBLIC_PRESENTATION_DEFINITION_MAX_BYTES=65536

# Wallet history retention in days; 0 keeps all events (default).
EXPO_PUBLIC_WALLET_HISTORY_RETENTION_DAYS=0
