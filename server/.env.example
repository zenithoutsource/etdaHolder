# Run: yarn setup   (from repo root — writes server/.env)
# Or copy these lines manually:

# Development defaults only. Production requires explicit values for all connection and security settings.
PORT=4000
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=etda_wallet
DB_USER=root
DB_PASSWORD=
# Replace with a strong secret before any non-test deployment; the development placeholder is rejected in production.
JWT_SECRET=local-dev-change-me
JWT_EXPIRES_IN=7d

# Browser/mobile origins allowed to call the backend. Production must use registered HTTPS origins.
WALLET_API_ALLOWED_ORIGINS=http://localhost:19006,http://localhost:8081

# Dev VP session TTL / issuer pin (legacy /dev/* routes — retained for LAN golden path)
# VP_SESSION_TTL_MS=300000
# VP_ISSUER_PUBLIC_KEY_JWK={"kty":"OKP","crv":"Ed25519","x":"..."}

# Reference verifier presentation service (/v1/* routes — deploy on verifier infrastructure in production).
# Public base URL embedded in verify QR links and KB-JWT aud. Development default: http://localhost:4000.
# Production requires PUBLIC_BASE_URL or an equivalent configured HTTPS presentation endpoint.
# PUBLIC_BASE_URL=https://wallet.example
# VERIFIER_PRESENTATION_BASE_URL=https://verifier.example
# Deprecated alias — use VERIFIER_PRESENTATION_BASE_URL in new deployments:
# PRESENTATION_GATEWAY_BASE_URL=https://gateway.example
# Session TTL in ms before QR expires (default 300000 = 5 minutes)
# PRESENTATION_SESSION_TTL_MS=300000
# Issuer JWKS cache TTL in ms when resolving keys from metadata (default 3600000 = 1 hour)
# PRESENTATION_ISSUER_JWKS_CACHE_MS=3600000

# Production Issuer URL for renewal and issuer JWKS resolution. Required when those flows are enabled.
# ISSUER_BASE_URL=https://issuer.example
