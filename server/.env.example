PORT=4000
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=etda_wallet
DB_USER=root
DB_PASSWORD=
JWT_SECRET=local-dev-change-me
JWT_EXPIRES_IN=7d

# Office-network workaround: forwards /dev-issuer-proxy/* to ISSUER_PROXY_TARGET via
# this PC's VPN. Phone reaches it through `adb reverse tcp:4000 tcp:4000`.
# Do not enable in prod.
ENABLE_DEV_ISSUER_PROXY=false
ISSUER_PROXY_TARGET=

# Office-network workaround for OID4VP Verifier calls. Forwards
# /dev-verifier-proxy/* to VERIFIER_PROXY_TARGET via this PC.
ENABLE_DEV_VERIFIER_PROXY=false
VERIFIER_PROXY_TARGET=

# Standalone Phase 2A test mDOC issuer. This is a separate Express app under
# server/mdoc-issuer/, not part of the Wallet Backend routes.
MDOC_ISSUER_PORT=4100
MDOC_ISSUER_BASE_URL=http://127.0.0.1:4100
