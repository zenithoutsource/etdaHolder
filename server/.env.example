# Run: yarn setup   (from repo root — writes server/.env)
# Or copy these lines manually:

PORT=4000
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=etda_wallet
DB_USER=root
DB_PASSWORD=
JWT_SECRET=local-dev-change-me
JWT_EXPIRES_IN=7d

# Dev VP relay (legacy /dev/* routes — retained for LAN golden path)
# VP_RELAY_BASE_URL=http://192.168.1.10:4000
# VP_SESSION_TTL_MS=300000
# VP_ISSUER_PUBLIC_KEY_JWK={"kty":"OKP","crv":"Ed25519","x":"..."}

# Reference verifier presentation service (/v1/* routes — deploy on verifier infrastructure in production).
# Public HTTPS base URL embedded in verify QR links and KB-JWT aud (default: PRESENTATION_GATEWAY_BASE_URL, VP_RELAY_BASE_URL, then http://localhost:4000).
# VERIFIER_PRESENTATION_BASE_URL=https://verifier.example
# Deprecated alias — use VERIFIER_PRESENTATION_BASE_URL in new deployments:
# PRESENTATION_GATEWAY_BASE_URL=https://gateway.example
# Session TTL in ms before QR expires (default 300000 = 5 minutes)
# PRESENTATION_SESSION_TTL_MS=300000
# Issuer JWKS cache TTL in ms when resolving keys from metadata (default 3600000 = 1 hour)
# PRESENTATION_ISSUER_JWKS_CACHE_MS=3600000

# Optional: see server/.env.development.local.example
