# Optional server development overrides — copy to server/.env.development.local (gitignored).
# NOT required for first run. See docs/GETTING_STARTED.md.

# PIN reset email (SMTP). When SMTP_HOST is empty, OTP is logged to the server console.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=wallet-noreply@localhost
MAIL_FROM_NAME=ETDA Wallet

# Dev VP session (legacy /dev/* routes).
VP_SESSION_TTL_MS=300000
VERIFIER_PRESENTATION_BASE_URL=http://localhost:4000
VP_ISSUER_PUBLIC_KEY_JWK={"kty":"OKP","crv":"Ed25519","x":"<issuer-x>"}
