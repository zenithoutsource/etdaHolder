# Optional server development overrides — copy to server/.env.development.local (gitignored).
# NOT required for first run. See docs/GETTING_STARTED.md.

# PIN reset email (SMTP). When SMTP_HOST is empty, OTP is logged to the server console.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=wallet-noreply@localhost
MAIL_FROM_NAME=ETDA Wallet

# Office-network workaround: forwards /dev-issuer-proxy/* to ISSUER_PROXY_TARGET via
# this PC's VPN. Phone reaches it through `adb reverse tcp:4000 tcp:4000`.
# Do not enable in prod.
ENABLE_DEV_ISSUER_PROXY=false
ISSUER_PROXY_TARGET=

# Office-network workaround for OID4VP Verifier calls.
ENABLE_DEV_VERIFIER_PROXY=false
VERIFIER_PROXY_TARGET=

# Standalone Phase 2A test mDOC issuer (server/mdoc-issuer/).
MDOC_ISSUER_PORT=4100
MDOC_ISSUER_BASE_URL=http://127.0.0.1:4100

# VP relay (wallet-initiated QR, dev only).
VP_SESSION_TTL_MS=300000
VP_RELAY_BASE_URL=http://localhost:4000
VP_ISSUER_PUBLIC_KEY_JWK={"kty":"OKP","crv":"Ed25519","x":"<issuer-x>"}
