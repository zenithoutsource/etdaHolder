# Run: yarn setup
# That writes a minimal .env with the backend URL and push registration enabled.
# Add EXPO_PUBLIC_SKIP_PUSH_REGISTRATION=true only when push delivery is intentionally disabled.
#
# Optional dev overrides: copy .env.development.local.example → .env.development.local
# Full guide: docs/GETTING_STARTED.md

# Screen capture prevention on Wallet Home, Credential Detail, Scan, and History.
# Set to true to allow tester screenshots on sensitive screens. Default: guard active.
# EXPO_PUBLIC_DISABLE_SCREEN_CAPTURE_GUARD=true

# OID4VP issuer relying-party trust entry for PID auth requests.
# Client ID is normalized to decentralized_identifier:<did> when the prefix is omitted.
# EXPO_PUBLIC_ISSUER_OID4VP_DID_WEB_CLIENT_ID=did:web:issuer.example.com
# EXPO_PUBLIC_ISSUER_OID4VP_DID_WEB_RESPONSE_ORIGIN=https://issuer.example.com
# EXPO_PUBLIC_ISSUER_OID4VP_DID_WEB_NAME=PID Issuer
# EXPO_PUBLIC_ISSUER_OID4VP_DID_WEB_JWK={"kty":"OKP","crv":"Ed25519","x":"..."}

# Production OID4VP Verifier trust (release builds). Required instead of EXPO_PUBLIC_VERIFIER_API_BASE_URL.
# EXPO_PUBLIC_VERIFIER_DID_WEB_CLIENT_ID=did:web:verifier.example.com
# EXPO_PUBLIC_VERIFIER_DID_WEB_RESPONSE_ORIGIN=https://verifier.example.com
# EXPO_PUBLIC_VERIFIER_DID_WEB_NAME=Trusted Verifier
# EXPO_PUBLIC_VERIFIER_DID_WEB_JWK={"kty":"OKP","crv":"Ed25519","x":"..."}

# OID4VP did:web DID document fetch policy.
# Timeout in ms before aborting did.json fetch (default 15000).
EXPO_PUBLIC_DID_WEB_FETCH_TIMEOUT_MS=15000
# Max did.json response body size in UTF-8 bytes before JSON parse (default 65536).
EXPO_PUBLIC_DID_WEB_MAX_BYTES=65536

# Deprecated for production My QR — superseded by the Wallet Broker path below.
# My QR — verifier-owned presentation service base URL (HTTPS in production).
# KB-JWT aud and verify QR links use this host. Wallet company backend is NOT in this path.
# EXPO_PUBLIC_VERIFIER_PRESENTATION_BASE_URL=https://verifier.example
# Deprecated fallbacks (use VERIFIER_PRESENTATION_BASE_URL in new deployments):
# EXPO_PUBLIC_PRESENTATION_GATEWAY_BASE_URL=http://192.168.1.10:4000
# EXPO_PUBLIC_VP_RELAY_BASE_URL=http://192.168.1.10:4000

# My QR — Wallet Broker (engagement QR + deposited OID4VP request).
# EXPO_PUBLIC_BROKER_BASE_URL=https://wallet.zenithcomp.co.th:455

# Dev-only NFC/HCE smoke test: how long the "Test NFC (arm HCE)" button keeps the
# companion session armed, in milliseconds. Default 120000 (120s). Only used in
# __DEV__ builds; longer values give more time to tap the reader before auto-disarm.
# EXPO_PUBLIC_NFC_TEST_ARM_WINDOW_MS=120000
