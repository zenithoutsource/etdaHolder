EXPO_PUBLIC_WALLET_API_BASE_URL=http://<windows-lan-ip>:4000

# Set to true to skip Expo push token registration in development.
# Use when your dev network cannot reach exp.host and you don't need push notifications locally.
EXPO_PUBLIC_SKIP_PUSH_REGISTRATION=

# Development-only wallet operation logs. Defaults to enabled in __DEV__ when unset.
# Set to false to mute [wallet:*] logs. Production builds ignore this flag and stay off.
# Logs are redacted: tokens, VC/VP payloads, credential claims, PII, and key material
# must never be printed.
EXPO_PUBLIC_ENABLE_WALLET_DEBUG_LOGS=true

# Comma-separated native cert resource names (no extension) bundled into the iOS/Android
# projects via Expo prebuild. Only used to pin HTTPS connections to the backend host
# above (ADR 0005). Leave empty to disable pinning, e.g. for local HTTP dev backends.
EXPO_PUBLIC_WALLET_API_PINNED_CERTS=

# Office-network workaround: rewrites fetches to EXPO_PUBLIC_DEV_ISSUER_PROXY_TARGET
# to go through the local backend's /dev-issuer-proxy instead (see server/.env
# ENABLE_DEV_ISSUER_PROXY). Leave unset in normal/prod use.
EXPO_PUBLIC_DEV_ISSUER_PROXY_TARGET=
EXPO_PUBLIC_DEV_ISSUER_PROXY_BASE_URL=

# OID4VP Verifier API used by Scan for presentation testing.
# Example: http://192.100.10.48
EXPO_PUBLIC_VERIFIER_API_BASE_URL=
EXPO_PUBLIC_VERIFIER_NAME=Verifier API
EXPO_PUBLIC_DEV_VERIFIER_PROXY_TARGET=
EXPO_PUBLIC_DEV_VERIFIER_PROXY_BASE_URL=

# Development-only compatibility switch for Verifiers that omit
# require_cryptographic_holder_binding while test credentials lack cnf.jwk.
# Never enable for release builds.
# Wallet key TTL. Omit to use defaults (dev=300000ms, prod=15552000000ms).
EXPO_PUBLIC_WALLET_KEY_DEV_TTL_MS=300000
EXPO_PUBLIC_WALLET_KEY_PROD_TTL_MS=15552000000

EXPO_PUBLIC_DISABLE_SD_JWT_KB_FOR_TESTING=

# Development-only OID4VP Verifier compatibility probes for generic
# "Present VP is invalid" responses. Defaults are spec-aligned.
# EXPO_PUBLIC_VERIFIER_DCQL_VP_TOKEN_SHAPE=object_array
# Alternate probes: object_string, raw
EXPO_PUBLIC_VERIFIER_DCQL_VP_TOKEN_SHAPE=
# EXPO_PUBLIC_VERIFIER_KB_AUD=client_id
# Alternate probe: response_uri
EXPO_PUBLIC_VERIFIER_KB_AUD=
